configuration {
    modi:                       "drun,run,window";
    show-icons:                 true;
    icon-theme:                 "Papirus";
    display-drun:               " Apps";
    display-run:                " Run";
    display-window:             " Windows";
    drun-display-format:        "{icon} {name}";
    font:                       "JetBrainsMono Nerd Font 11";
    disable-history:            false;
    hide-scrollbar:             true;
    sidebar-mode:               false;
}

@theme "catppuccin-mocha"
